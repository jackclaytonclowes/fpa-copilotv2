# ─────────────────────────────────────────────────────────────────────────────
# Backend — set these in Render (Environment → Environment Variables)
# ─────────────────────────────────────────────────────────────────────────────

# Required: OpenAI key for the Q&A Copilot feature
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Required for split deployment: comma-separated list of allowed frontend origins
# Example: https://monthendiq.vercel.app,https://monthendiq-*.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# Frontend build — set these in Vercel (Project → Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────────────────────

# Required for split deployment: your Render API service URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://your-api.onrender.com
