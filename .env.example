# ─────────────────────────────────────────────────────────────────────────────
# Backend — set these in Render (Environment → Environment Variables)
# ─────────────────────────────────────────────────────────────────────────────

# Required: OpenAI key for the Q&A Copilot feature
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: Xero OAuth 2.0 — register at https://developer.xero.com/app/manage
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:8000/api/xero/callback

# Required for split deployment: comma-separated list of allowed frontend origins
# Example: https://monthendiq.vercel.app,https://monthendiq-*.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# Optional: path to the SQLite database file (default: portfolio.db in project root)
# On Render with a persistent disk, set this to the mount path, e.g. /data/portfolio.db
PORTFOLIO_DB=portfolio.db

# Optional: number of days before session data is automatically deleted (default: 30)
SESSION_TTL_DAYS=30

# Optional: set to "1" to enable verbose waterfall analysis logs in stderr
WATERFALL_DEBUG=

# ─────────────────────────────────────────────────────────────────────────────
# Email — set these in Render to enable the "Email management pack" feature
# ─────────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=
# Defaults to SMTP_USER if not set
EMAIL_FROM=

# ─────────────────────────────────────────────────────────────────────────────
# Frontend build — set these in Vercel (Project → Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────────────────────

# Required for split deployment: your Render API service URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://your-api.onrender.com
