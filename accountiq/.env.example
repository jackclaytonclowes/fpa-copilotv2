# Copy this file to .env.local and fill in your real values.
# Never commit .env.local — it is already listed in .gitignore.

# ------------------------------------------------------------------
# Supabase
# Find these in your Supabase project: Settings > API
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------------
# AI provider
# Set AI_PROVIDER to "openai" (default) or "anthropic".
# Only the key for the active provider is required.
# Optionally set AI_MODEL to override the default model for that provider.
#   OpenAI default:    gpt-4o-mini
#   Anthropic default: claude-sonnet-4-20250514
# ------------------------------------------------------------------
AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_key_here

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here
